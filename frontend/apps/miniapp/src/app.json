{
  "pages": [
    "pages/wrongbook/list/list",
    "pages/wrongbook/capture/capture",
    "pages/wrongbook/detail/detail"
  ],
  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "错题本",
    "navigationBarTextStyle": "black",
    "enablePullDownRefresh": true
  },
  "tabBar": {
    "color": "#1d1d1f",
    "selectedColor": "#0071e3",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      { "pagePath": "pages/wrongbook/list/list", "text": "错题" },
      { "pagePath": "pages/wrongbook/capture/capture", "text": "录入" }
    ]
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "useExtendedLib": {
    "kbone": false,
    "weui": false
  },
  "usingComponents": {
    "van-button": "@vant/weapp/button/index",
    "van-cell": "@vant/weapp/cell/index",
    "van-tag": "@vant/weapp/tag/index",
    "van-tab": "@vant/weapp/tab/index",
    "van-tabs": "@vant/weapp/tabs/index",
    "van-empty": "@vant/weapp/empty/index",
    "van-skeleton": "@vant/weapp/skeleton/index",
    "van-popup": "@vant/weapp/popup/index",
    "van-field": "@vant/weapp/field/index",
    "van-picker": "@vant/weapp/picker/index"
  }
}
